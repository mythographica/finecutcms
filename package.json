{
	"name": "finecut-node",
	"version": "1.0.0",
	"description": "FineCut CMS — Node.js + Fastify + mnemonica rewrite",
	"main": "build/src/core/server.js",
	"type": "module",
	"scripts": {
		"start": "node build/src/core/server.js",
		"dev": "node --watch build/src/core/server.js 2>&1 | tee -a server.log",
		"build": "tsc",
		"build:watch": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"cache:clear": "node bin/cache-clear.js",
		"tactica": "npx tactica --esm --verbose"
	},
	"dependencies": {
		"@fastify/formbody": "^8.0.2",
		"@fastify/static": "^9.1.3",
		"elfinder-node": "^2.1.1",
		"elfinder-npm": "^2.1.28",
		"fastify": "^5.0.0",
		"mnemonica": "file:../core",
		"pino": "^9.0.0",
		"pino-pretty": "^13.0.0"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@mnemonica/tactica": "file:../tactica",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"eslint": "^10.3.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
